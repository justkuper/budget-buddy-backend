{
  "name": "secure-finance-backend",
  "version": "1.0.0",
  "description": "Secure financial backend: AWS Cognito + TOTP 2FA, DynamoDB, Plaid (sandbox)",
  "main": "lambda/handler.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
